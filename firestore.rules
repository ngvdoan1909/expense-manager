rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isTransactionShape(data) {
      return data.keys().hasOnly([
        'type',
        'category',
        'amount',
        'periodType',
        'periodMonth',
        'paymentMethod',
        'note',
        'date',
        'day',
        'month',
        'year',
        'createdAt'
      ]);
    }

    function isAllowedCategory(data) {
      return (data.type == 'income' && data.category in ['Bán hàng', 'Lương', 'Thưởng'])
        || (data.type == 'expense' && data.category in [
          'Nhập hàng',
          'Tiền điện',
          'Tiền nước',
          'Tiền internet',
          'Tiền thuê mặt bằng',
          'Tiền lương',
          'Ăn uống',
          'Mua sắm',
          'Xăng xe'
        ]);
    }

    function isValidTransaction(data) {
      return isTransactionShape(data)
        && data.type in ['income', 'expense']
        && data.periodType in ['daily', 'monthly']
        && data.paymentMethod in ['cash', 'bank', 'card', 'wallet']
        && isAllowedCategory(data)
        && data.amount is number
        && data.amount >= 1000
        && data.amount <= 999999999999
        && data.note is string
        && data.note.size() <= 500
        && data.date is string
        && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.periodMonth is string
        && data.periodMonth.matches('^\\d{4}-\\d{2}$')
        && data.day is int
        && data.day >= 1
        && data.day <= 31
        && data.month is int
        && data.month >= 1
        && data.month <= 12
        && data.year is int
        && data.year >= 2000
        && data.year <= 2100;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;

      match /transactions/{transactionId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidTransaction(request.resource.data)
          && request.resource.data.createdAt == request.time;
        allow update: if isOwner(userId)
          && isValidTransaction(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
